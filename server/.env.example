# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/intellmeet

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT (use long random strings — min 32 chars) ──────────────────────────────
JWT_SECRET=<your-jwt-secret-min-32-chars>
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=<your-jwt-refresh-secret-min-32-chars>
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://app.intellmeet.com
CLIENT_URL=http://localhost:5173

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ── Cloudinary (media uploads) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=<your-cloudinary-cloud-name>
CLOUDINARY_API_KEY=<your-cloudinary-api-key>
CLOUDINARY_API_SECRET=<your-cloudinary-api-secret>

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=<your-openai-api-key>

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── SMTP (transactional email) ────────────────────────────────────────────────
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=<your-smtp-user>
SMTP_PASS=<your-smtp-password>
SMTP_FROM=noreply@intellmeet.com
