{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "allowJs": true,
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true
  },
  "include": [
    "src/**/*",
    "src/@types/**/*"
  ]
}