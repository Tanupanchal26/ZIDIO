# ─────────────────────────────────────────────────────────────────────────────
# IntellMeet — Server Environment Variables
# Copy to .env and fill in values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development           # development | staging | production | test
PORT=5000

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/intellmeet

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT — use strong random secrets in production (min 64 chars) ─────────────
JWT_SECRET=replace-with-a-strong-random-secret-minimum-64-chars-do-not-use-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-different-strong-random-secret-min-64-chars
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173
CLIENT_URL=http://localhost:5173

# ── Cookie domain (production only) ──────────────────────────────────────────
# COOKIE_DOMAIN=.intellmeet.com

# ── Google OAuth (optional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ── Cloudinary (file uploads) ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── OpenAI (AI features) ─────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── SMTP (email) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@intellmeet.com
SMTP_SECURE=false
