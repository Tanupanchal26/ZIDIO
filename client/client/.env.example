# ─────────────────────────────────────────────────────────────────────────────
# IntellMeet — Frontend Environment Variables
# Copy to .env and fill in values before running.
# All variables must be prefixed VITE_ to be exposed to the browser bundle.
# ─────────────────────────────────────────────────────────────────────────────

# ── API & Socket ─────────────────────────────────────────────────────────────
# Must match backend PORT and include /api/v1 path
VITE_API_BASE_URL=http://localhost:5000/api/v1
VITE_SOCKET_URL=http://localhost:5000

# ── Google OAuth client-side ID (public — safe to expose) ────────────────────
VITE_GOOGLE_CLIENT_ID=
